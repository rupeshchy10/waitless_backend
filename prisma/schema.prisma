generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum QueueStatus {
    WAITING
    SERVING
    COMPLETED
    CANCELLED
    EXPIRED
    NO_SHOW
}

enum Role {
    ADMIN
    STAFF
    USER
}

enum QueuePriority {
    NORMAL
    VIP
    EMERGENCY
}

model User {
    id String @id @default(uuid())

    fullName       String
    email          String  @unique
    password       String
    phoneNumber    String
    address        String
    profileImage   String?
    profileImageId String?

    role Role @default(USER)

    passwordResetOtpHash      String?
    passwordResetOtpExpiresAt DateTime?

    queues           Queue[]
    notifications    Notification[]
    staffAssignments StaffAssignment[]
    serviceCenters   ServiceCenter[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model ServiceCenter {
    id            String @id @default(uuid())
    name          String
    address       String
    email         String @unique
    phoneNumber   String
    counterNumber Int    @default(1)

    logo   String?
    logoId String?

    userId String
    user   User   @relation(fields: [userId], references: [id])

    queues           Queue[]
    staffAssignments StaffAssignment[]

    openingHour   Int @default(9)
    openingMinute Int @default(0)

    closingHour   Int @default(16)
    closingMinute Int @default(0)

    averageServiceTime Int @default(10)

    closedDays Int[] @default([])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model StaffAssignment {
    id String @id @default(uuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    serviceCenterId String
    serviceCenter   ServiceCenter @relation(fields: [serviceCenterId], references: [id])

    @@unique([userId, serviceCenterId])
}

model Queue {
    id          String @id @default(uuid())
    tokenNumber Int

    status   QueueStatus   @default(WAITING)
    priority QueuePriority @default(NORMAL)

    userId String
    user   User   @relation(fields: [userId], references: [id])

    serviceCenterId String
    serviceCenter   ServiceCenter @relation(fields: [serviceCenterId], references: [id])

    checkedIn Boolean @default(false)

    expiresAt   DateTime?
    servedAt    DateTime?
    completedAt DateTime?
    cancelledAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([serviceCenterId, tokenNumber])
    @@index([serviceCenterId, status])
    @@index([userId])
    @@index([tokenNumber])
}

model Notification {
    id String @id @default(uuid())

    userId String

    user User @relation(fields: [userId], references: [id])

    title String

    message String

    isRead Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
